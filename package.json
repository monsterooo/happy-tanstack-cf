{
	"name": "happy-tanstack-cf",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "pnpm -r dev",
		"build": "pnpm -r build",
		"check-types": "pnpm -r check-types",
		"dev:web": "pnpm --filter web dev",
		"db:push": "pnpm --filter @happy-tanstack-cf/db db:push",
		"db:generate": "pnpm --filter @happy-tanstack-cf/db db:generate",
		"deploy": "pnpm --filter @happy-tanstack-cf/infra deploy",
		"release:pre": "pnpm --filter @happy-tanstack-cf/infra release:pre",
		"release:prod": "pnpm --filter @happy-tanstack-cf/infra release:prod",
		"destroy": "pnpm --filter @happy-tanstack-cf/infra destroy",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@happy-tanstack-cf/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@cloudflare/workers-types": "^4.20251213.0",
		"@happy-tanstack-cf/config": "workspace:*",
		"@types/node": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@9.14.2"
}
